# Copy to .env at repository root before local or Docker runs.
# Keep secrets out of git.

# Optional runtime flags
ENVIRONMENT=production
LOG_LEVEL=INFO
RATE_LIMIT=60/minute

# Your public frontend URL (for backend CORS)
CORS_ORIGINS=http://your-server-ip:3000

# Database
DB_USER=root
DB_PASSWORD=change_me
DB_HOST=localhost
DB_PORT=3306
DB_NAME=viewingchart

# OpenAI
OPENAI_API_KEY=

# iTick API
ITICK_API_URL=https://api.itick.org
ITICK_API_TOKEN=

# Alpha Vantage
ALPHAVANTAGE_API_KEY=demo
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# Yahoo Finance
YAHOO_SEARCH_URL=https://query2.finance.yahoo.com/v1/finance/search
YAHOO_TRENDING_URL=https://query2.finance.yahoo.com/v1/finance/trending/US

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Binance
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com
BINANCE_API_URL=https://api.binance.com/api/v3
BINANCE_FUTURES_API_URL=https://fapi.binance.com/fapi/v1

# Frontend public endpoints (embedded into Next.js at build time)
NEXT_PUBLIC_API_URL=http://your-server-ip:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://your-server-ip:8000/api/v1
