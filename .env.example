# Copy to .env at repository root before local or Docker runs.
# Keep secrets out of git.

# Optional runtime flags
ENVIRONMENT=production
LOG_LEVEL=INFO
RATE_LIMIT=60/minute
STOCK_QUOTE_TTL_ACTIVE=10
STOCK_QUOTE_TTL_CLOSED=60

# Browser Origin(s) allowed by the API (comma-separated). Must match what users open in the
# browser (scheme + host + port if non-default). Examples: https://chart.example.com or
# http://your-server-ip:443 when nginx is plain HTTP mapped to host port 443.
CORS_ORIGINS=https://chart.example.com

# Database
DB_USER=root
DB_PASSWORD=change_me
DB_HOST=localhost
DB_PORT=3306
DB_NAME=viewingchart

# OpenAI
OPENAI_API_KEY=

# iTick API
ITICK_API_URL=https://api.itick.org
ITICK_API_TOKEN=

# Alpha Vantage
ALPHAVANTAGE_API_KEY=demo
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# Yahoo Finance
YAHOO_SEARCH_URL=https://query2.finance.yahoo.com/v1/finance/search
YAHOO_TRENDING_URL=https://query2.finance.yahoo.com/v1/finance/trending/US

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# If Redis uses requirepass, set this (do not commit real secrets). Leave empty for no AUTH.
# REDIS_PASSWORD=

# Binance
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com
BINANCE_API_URL=https://api.binance.com/api/v3
BINANCE_FUTURES_API_URL=https://fapi.binance.com/fapi/v1

# Frontend public endpoints (embedded into Next.js at build time).
# Docker Compose + nginx (recommended): path-only API and omit WS so the browser uses the same host.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_WS_URL=
# Host port published for nginx (default 443). Override for local tests, e.g. PUBLIC_PORT=8443
# PUBLIC_PORT=443
#
# Non-Docker / direct ports (e.g. ./start_app.sh dev):
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1
