# ── ViewingChart .env Configuration ──
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Environment ──
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT=60/minute

# ── Database (MariaDB) ──
DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306
DB_NAME=viewingchart

# ── OpenAI (optional — chat runs in mock mode without it) ──
OPENAI_API_KEY=

# ── iTick API ──
ITICK_API_URL=https://api.itick.org
ITICK_API_TOKEN=your_itick_token_here

# ── Alpha Vantage ──
ALPHAVANTAGE_API_KEY=demo
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# ── Yahoo Finance ──
YAHOO_SEARCH_URL=https://query2.finance.yahoo.com/v1/finance/search
YAHOO_TRENDING_URL=https://query2.finance.yahoo.com/v1/finance/trending/US

# ── Redis & WebSockets ──
REDIS_HOST=localhost
REDIS_PORT=6379
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com
BINANCE_API_URL=https://api.binance.com/api/v3
BINANCE_FUTURES_API_URL=https://fapi.binance.com/fapi/v1

# ── Monitor (/health, /ws/status JSON size limits; optional) ──
# MONITOR_STATUS_SYMBOLS_CAP=50
# MONITOR_STATUS_STREAMS_CAP=50
# MONITOR_STATUS_KLINE_ROOMS_CAP=40
